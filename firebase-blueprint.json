{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account information and settings.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "username": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "createdAt": { "type": "string", "format": "date-time" },
        "isAdmin": { "type": "boolean" }
      },
      "required": ["userId", "username", "email", "createdAt"]
    },
    "SafetyReport": {
      "title": "Safety Report",
      "description": "Community data about safety at specific coordinates.",
      "type": "object",
      "properties": {
        "reportId": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["danger", "safety"] },
        "category": { "type": "string" },
        "severity": { "type": "number" },
        "description": { "type": "string" },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["reportId", "userId", "type", "category", "latitude", "longitude", "timestamp"]
    },
    "SOSEvent": {
      "title": "SOS Event",
      "description": "Emergency alert triggered by a user.",
      "type": "object",
      "properties": {
        "sosId": { "type": "string" },
        "userId": { "type": "string" },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["active", "resolved"] }
      },
      "required": ["sosId", "userId", "latitude", "longitude", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Information about application users."
    },
    "/reports/{reportId}": {
      "schema": "SafetyReport",
      "description": "Geospatial safety reports from the community."
    },
    "/sos_events/{sosId}": {
      "schema": "SOSEvent",
      "description": "Active and past emergency SOS signals."
    }
  }
}
